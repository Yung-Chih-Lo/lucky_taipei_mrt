# 複製本檔為 .env.local 後填入實際值：cp .env.example .env.local

# SQLite 資料庫路徑（相對於專案根目錄）
DATABASE_PATH=./data/metro.db

# iron-session 加密用的 secret，至少 32 字元
# 產生方式：openssl rand -base64 48
SESSION_SECRET=replace-with-random-string-at-least-32-chars

# 後台管理員帳號
ADMIN_USERNAME=admin

# 後台管理員密碼的 argon2id hash
# 產生方式：npm run hash-password -- '你的密碼'
# ⚠️ hash 裡每個 $ 都要用 \$ 跳脫，否則會被 Next.js env loader 當變數展開
# 範例：ADMIN_PASSWORD_HASH=\$argon2id\$v=19\$m=...\$salt\$hash
ADMIN_PASSWORD_HASH=replace-with-argon2id-hash

NEXT_PUBLIC_SITE_URL=https://your-domain.com